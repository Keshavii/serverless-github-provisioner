# ============================================
# GitHub App Configuration (Recommended)
# ============================================
# GitHub App ID (from GitHub App settings)
GITHUB_APP_ID=1234567

# GitHub App Private Key (PEM format)
# For local development, use the full PEM content or path to .pem file
# For Lambda, this will be loaded from AWS Secrets Manager
GITHUB_APP_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----
MIIEpAIBAAKCAQEA...
...your private key here...
-----END RSA PRIVATE KEY-----

# ============================================
# GitHub Configuration (Legacy - Optional)
# ============================================
# Personal Access Token (legacy authentication, optional)
GITHUB_TOKEN=ghp_your_github_personal_access_token_here


# JIRA Configuration
JIRA_URL=https://your-company.atlassian.net
JIRA_EMAIL=your-email@company.com
JIRA_API_TOKEN=your_jira_api_token_here

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json
ENABLE_METRICS=true

# Environment
ENVIRONMENT=development

# ============================================
# JIRA Ticket Transition Configuration
# ============================================

# --- Success Handling ---
# Auto-transition tickets to Done when repository is created successfully
AUTO_TRANSITION_ON_SUCCESS=true

# Target status name for successful tickets (must exist in your JIRA workflow)
SUCCESS_TRANSITION_NAME=Done

# Resolution to set (required by some JIRA workflows, leave empty if not needed)
SUCCESS_RESOLUTION=

# --- Failure Handling ---
# Auto-transition tickets to Manual Review when repository creation fails (after all retries)
AUTO_TRANSITION_ON_FAILURE=false

# Target status name for failed tickets (must exist in your JIRA workflow)
# Common options: "Manual Review", "To Do", "Blocked", "Needs Review"
FAILURE_TRANSITION_NAME=Manual Review

# Resolution to set for failed tickets (leave empty or use "Unresolved")
FAILURE_RESOLUTION=

# ============================================
# JIRA Custom Field Mappings
# ============================================
# These custom field IDs are specific to your JIRA instance
# To find your custom field IDs:
#   1. Go to JIRA → Settings → Issues → Custom Fields
#   2. Click on the field name
#   3. Look at the URL: ...customfield_XXXXX
#   4. Use the customfield_XXXXX as the value below
#
# Alternatively, fetch a ticket and inspect the JSON response to see field IDs

# --- Data Extraction Method ---
# Set to 'true' to use custom fields (recommended for JIRA forms)
# Set to 'false' to use JSON parsing from description field
USE_CUSTOM_FIELDS=true

# --- Repository Details Fields ---
# Repository name (e.g., "my-service-name")
JIRA_FIELD_REPO_NAME=customfield_27191

# GitHub organization (e.g., "tekion-foundation", "tekion-poc")
JIRA_FIELD_GITHUB_ORG=customfield_27192

# Repository type (e.g., "Private", "Internal")
JIRA_FIELD_REPO_TYPE=customfield_27193

# Code type (e.g., "Java", "Python", "Nodejs", "Go")
JIRA_FIELD_CODE_TYPE=customfield_27194

# --- Ownership Details Fields ---
# VP name
JIRA_FIELD_VP_NAME=customfield_27195

# Director name
JIRA_FIELD_DIRECTOR=customfield_27196

# Engineering Manager name
JIRA_FIELD_EM_NAME=customfield_27197

# Product line (e.g., "ARC", "Infra", "Platform")
JIRA_FIELD_PRODUCT_LINE=customfield_14984

# NOTE: If your JIRA instance uses different custom field IDs, update the values above.
# The field IDs will be the same for all tickets created with the same JIRA form.
