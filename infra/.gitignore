# ============================================================================
# Terraform .gitignore for Infrastructure
# ============================================================================

# ============================================================================
# SECRETS - NEVER COMMIT THESE!
# ============================================================================
# Terraform variable files with secrets
*.tfvars
*.tfvars.json
terraform.tfvars
terraform.tfvars.json

# Secret files
secrets/
*.secret
*.key
*.pem

# ============================================================================
# Terraform State Files - Contains sensitive data
# ============================================================================
*.tfstate
*.tfstate.*
*.tfstate.backup

# Crash log files
crash.log
crash.*.log

# ============================================================================
# Terraform Working Directories
# ============================================================================
.terraform/
.terraform.lock.hcl

# ============================================================================
# Lambda Deployment Packages
# ============================================================================
*.zip
lambda-*.zip
deployment-package-*.zip

# Lambda layer packages
modules/lambda-layer/layer/
modules/lambda-layer/python/
modules/lambda-layer/*.zip

# ============================================================================
# Log Files
# ============================================================================
*.log

# ============================================================================
# Temporary Files
# ============================================================================
*.tmp
*.temp
.DS_Store
.idea/
.vscode/
*.swp
*.swo
*~

# ============================================================================
# Terraform Plan Files
# ============================================================================
*.tfplan
tfplan
plan.out

# ============================================================================
# Override Files
# ============================================================================
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# ============================================================================
# CLI Configuration Files
# ============================================================================
.terraformrc
terraform.rc
